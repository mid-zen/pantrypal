{
  "expo": {
    "name": "PantryPal",
    "slug": "pantrypal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantrypal.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PantryPal needs camera access to scan barcodes on food items.",
        "NSMicrophoneUsageDescription": "PantryPal needs microphone access for barcode scanning."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pantrypal.app",
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PantryPal to access camera to scan barcodes."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "ceaaaa13-9f3d-4b72-b0b1-d537ebbf60de"
      }
    },
    "sdkVersion": "54.0.0",
    "owner": "midzenga"
  }
}
